{
  "info": {
    "title": "HISAAB API",
    "description": "A modern API for financial management and tracking (Node.js/Express/PostgreSQL)",
    "version": "1.0.0",
    "baseUrl": "/api"
  },
  "authentication": {
    "type": "Bearer Token",
    "header": "Authorization",
    "format": "Bearer <access_token>",
    "tokenExpiry": "30 days"
  },
  "endpoints": {
    "auth": {
      "basePath": "/api/auth",
      "description": "User authentication and session management",
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/auth/register",
          "description": "Register a new user and create a default account",
          "authRequired": false,
          "requestBody": {
            "contentType": "application/json",
            "required": ["name", "email", "password", "account_name"],
            "schema": {
              "name": { "type": "string", "description": "User's full name" },
              "email": { "type": "string", "format": "email", "description": "User's email address" },
              "password": { "type": "string", "description": "User's password" },
              "account_name": { "type": "string", "description": "Name for the default account" }
            },
            "example": {
              "name": "Test User",
              "email": "test@example.com",
              "password": "password123",
              "account_name": "My Main Account"
            }
          },
          "responses": {
            "201": {
              "description": "User registered successfully",
              "schema": {
                "user": { "type": "object", "description": "User object (without password)" },
                "access_token": { "type": "string", "description": "JWT access token" },
                "token_type": { "type": "string", "value": "bearer" },
                "account": { "type": "object", "description": "Default account created" }
              }
            },
            "400": { "description": "Missing required fields" },
            "409": { "description": "Email already registered" }
          }
        },
        {
          "method": "POST",
          "path": "/api/auth/login",
          "description": "Login and get JWT token",
          "authRequired": false,
          "requestBody": {
            "contentType": "application/json",
            "required": ["username", "password"],
            "schema": {
              "username": { "type": "string", "description": "User's email address" },
              "password": { "type": "string", "description": "User's password" }
            },
            "example": {
              "username": "test@example.com",
              "password": "password123"
            }
          },
          "responses": {
            "200": {
              "description": "Login successful",
              "schema": {
                "user": { "type": "object" },
                "access_token": { "type": "string" },
                "token_type": { "type": "string", "value": "bearer" },
                "account": { "type": "object", "description": "Default account" }
              }
            },
            "400": { "description": "Missing credentials" },
            "401": { "description": "Invalid credentials" }
          }
        },
        {
          "method": "GET",
          "path": "/api/auth/me",
          "description": "Get current authenticated user info",
          "authRequired": true,
          "responses": {
            "200": {
              "description": "User info",
              "schema": {
                "id": { "type": "string", "format": "uuid" },
                "name": { "type": "string" },
                "email": { "type": "string" },
                "createdAt": { "type": "string", "format": "date-time" },
                "updatedAt": { "type": "string", "format": "date-time" }
              }
            },
            "401": { "description": "Unauthorized" }
          }
        },
        {
          "method": "POST",
          "path": "/api/auth/logout",
          "description": "Logout (blacklist current token)",
          "authRequired": true,
          "responses": {
            "200": {
              "description": "Logged out successfully",
              "schema": { "message": { "type": "string", "value": "Logged out" } }
            },
            "400": { "description": "No token provided" }
          }
        },
        {
          "method": "GET",
          "path": "/api/auth/inspect-token",
          "description": "Debug endpoint to inspect JWT token claims (development only)",
          "authRequired": false,
          "headers": {
            "Authorization": "Bearer <token>"
          },
          "responses": {
            "200": {
              "description": "Token analysis",
              "schema": {
                "header": { "type": "object" },
                "payload": { "type": "object" },
                "analysis": {
                  "type": "object",
                  "properties": {
                    "issued_at": { "type": "string", "format": "date-time" },
                    "expires_at": { "type": "string", "format": "date-time" },
                    "expires_in_seconds": { "type": "number" },
                    "expires_in_hours": { "type": "string" },
                    "expires_in_days": { "type": "string" },
                    "is_expired": { "type": "boolean" },
                    "is_valid": { "type": "boolean" },
                    "is_blacklisted": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "accounts": {
      "basePath": "/api/accounts",
      "description": "Manage user accounts (e.g., Cash, Bank accounts)",
      "authRequired": true,
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/accounts",
          "description": "List all accounts for the current user",
          "responses": {
            "200": {
              "description": "Array of accounts",
              "schema": {
                "type": "array",
                "items": {
                  "id": { "type": "string", "format": "uuid" },
                  "user_id": { "type": "string", "format": "uuid" },
                  "name": { "type": "string" },
                  "balance": { "type": "number" },
                  "default": { "type": "boolean" },
                  "created_at": { "type": "string", "format": "date-time" },
                  "updated_at": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        {
          "method": "POST",
          "path": "/api/accounts",
          "description": "Create a new account",
          "requestBody": {
            "contentType": "application/json",
            "required": ["name"],
            "schema": {
              "name": { "type": "string", "description": "Account name" },
              "balance": { "type": "number", "default": 0, "description": "Initial balance" }
            },
            "example": { "name": "Bank Account", "balance": 0 }
          },
          "responses": {
            "201": { "description": "Account created" },
            "400": { "description": "Account name is required" }
          }
        },
        {
          "method": "GET",
          "path": "/api/accounts/balance",
          "description": "Get total balance across all accounts",
          "responses": {
            "200": {
              "schema": { "total_balance": { "type": "number" } }
            }
          }
        },
        {
          "method": "GET",
          "path": "/api/accounts/:id",
          "description": "Get a specific account by ID",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "responses": {
            "200": { "description": "Account details" },
            "404": { "description": "Account not found" }
          }
        },
        {
          "method": "PUT",
          "path": "/api/accounts/:id",
          "description": "Update an account",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "requestBody": {
            "schema": {
              "name": { "type": "string" },
              "balance": { "type": "number" }
            }
          },
          "responses": {
            "200": { "description": "Account updated" },
            "404": { "description": "Account not found" }
          }
        },
        {
          "method": "DELETE",
          "path": "/api/accounts/:id",
          "description": "Delete an account",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "responses": {
            "204": { "description": "Account deleted" },
            "404": { "description": "Account not found" }
          }
        },
        {
          "method": "GET",
          "path": "/api/accounts/:id/transactions",
          "description": "Get all transactions for a specific account",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true },
            "start_date": { "in": "query", "type": "string", "format": "date" },
            "end_date": { "in": "query", "type": "string", "format": "date" },
            "transaction_type": { "in": "query", "type": "string", "enum": ["sale", "expense", "transfer", "other"] }
          },
          "responses": {
            "200": { "description": "Array of transactions" },
            "404": { "description": "Account not found" }
          }
        },
        {
          "method": "PATCH",
          "path": "/api/accounts/:id/set-default",
          "description": "Set an account as the default account",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "responses": {
            "200": {
              "schema": {
                "message": { "type": "string" },
                "account": { "type": "object" }
              }
            },
            "404": { "description": "Account not found" }
          }
        }
      ]
    },
    "transactions": {
      "basePath": "/api/transactions",
      "description": "Manage financial transactions (sales, expenses, transfers)",
      "authRequired": true,
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/transactions",
          "description": "List all transactions with optional filters",
          "parameters": {
            "start_date": { "in": "query", "type": "string", "format": "date" },
            "end_date": { "in": "query", "type": "string", "format": "date" },
            "transaction_type": { "in": "query", "type": "string", "enum": ["sale", "expense", "transfer", "other"] },
            "category": { "in": "query", "type": "string" },
            "account_id": { "in": "query", "type": "string", "format": "uuid" }
          },
          "responses": {
            "200": { "description": "Array of transactions" }
          }
        },
        {
          "method": "POST",
          "path": "/api/transactions",
          "description": "Create a new transaction",
          "requestBody": {
            "contentType": "application/json",
            "required": ["amount", "description", "transaction_type"],
            "schema": {
              "amount": { "type": "number", "description": "Transaction amount" },
              "description": { "type": "string", "description": "Transaction description" },
              "transaction_type": { "type": "string", "enum": ["sale", "expense", "transfer", "other"] },
              "category": { "type": "string" },
              "date": { "type": "string", "format": "date-time" },
              "account_id": { "type": "string", "format": "uuid" }
            },
            "example": {
              "amount": 100,
              "description": "Office supplies",
              "transaction_type": "expense",
              "category": "Office",
              "account_id": "uuid-here"
            }
          },
          "responses": {
            "201": { "description": "Transaction created" },
            "400": { "description": "Missing required fields" },
            "404": { "description": "Account not found" }
          }
        },
        {
          "method": "GET",
          "path": "/api/transactions/totals",
          "description": "Get transaction totals (total sales, expenses, balance)",
          "responses": {
            "200": {
              "schema": {
                "total_sales": { "type": "number" },
                "total_expenses": { "type": "number" },
                "balance": { "type": "number" }
              }
            }
          }
        },
        {
          "method": "GET",
          "path": "/api/transactions/:id",
          "description": "Get a specific transaction",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "responses": {
            "200": { "description": "Transaction details" },
            "404": { "description": "Transaction not found" }
          }
        },
        {
          "method": "PUT",
          "path": "/api/transactions/:id",
          "description": "Update a transaction",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "requestBody": {
            "schema": {
              "amount": { "type": "number" },
              "description": { "type": "string" },
              "transaction_type": { "type": "string", "enum": ["sale", "expense", "transfer", "other"] },
              "category": { "type": "string" },
              "date": { "type": "string", "format": "date-time" },
              "account_id": { "type": "string", "format": "uuid" }
            }
          },
          "responses": {
            "200": { "description": "Transaction updated" },
            "404": { "description": "Transaction not found" }
          }
        },
        {
          "method": "DELETE",
          "path": "/api/transactions/:id",
          "description": "Delete a transaction",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "responses": {
            "204": { "description": "Transaction deleted" },
            "404": { "description": "Transaction not found" }
          }
        }
      ]
    },
    "invoices": {
      "basePath": "/api/invoices",
      "description": "Manage invoices with line items and tax calculations",
      "authRequired": true,
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/invoices",
          "description": "List all invoices with optional filters",
          "parameters": {
            "status": { "in": "query", "type": "string", "enum": ["draft", "sent", "paid", "cancelled", "overdue"] },
            "start_date": { "in": "query", "type": "string", "format": "date" },
            "end_date": { "in": "query", "type": "string", "format": "date" },
            "customer_name": { "in": "query", "type": "string" }
          },
          "responses": {
            "200": { "description": "Array of invoices with items" }
          }
        },
        {
          "method": "POST",
          "path": "/api/invoices",
          "description": "Create a new invoice with items",
          "requestBody": {
            "contentType": "application/json",
            "required": ["customer_name"],
            "schema": {
              "invoice_number": { "type": "string", "description": "Auto-generated if not provided" },
              "customer_name": { "type": "string" },
              "customer_email": { "type": "string", "format": "email" },
              "customer_address": { "type": "string" },
              "issue_date": { "type": "string", "format": "date" },
              "due_date": { "type": "string", "format": "date" },
              "tax_rate": { "type": "number", "default": 18 },
              "status": { "type": "string", "enum": ["draft", "sent", "paid", "cancelled", "overdue"], "default": "draft" },
              "notes": { "type": "string" },
              "template": { "type": "string", "enum": ["default", "professional", "simple", "detailed"] },
              "items": {
                "type": "array",
                "items": {
                  "description": { "type": "string", "required": true },
                  "quantity": { "type": "number", "default": 1 },
                  "unit_price": { "type": "number", "required": true },
                  "amount": { "type": "number" },
                  "tax_included": { "type": "boolean", "default": true }
                }
              }
            },
            "example": {
              "customer_name": "Acme Corp",
              "customer_email": "billing@acme.com",
              "tax_rate": 18,
              "items": [
                { "description": "Web Development", "quantity": 10, "unit_price": 100, "tax_included": false },
                { "description": "Hosting (1 year)", "quantity": 1, "unit_price": 200, "tax_included": true }
              ]
            }
          },
          "responses": {
            "201": { "description": "Invoice created with calculated totals" },
            "400": { "description": "customer_name is required" }
          }
        },
        {
          "method": "GET",
          "path": "/api/invoices/:id",
          "description": "Get a specific invoice with items",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "responses": {
            "200": { "description": "Invoice with items" },
            "404": { "description": "Invoice not found" }
          }
        },
        {
          "method": "PUT",
          "path": "/api/invoices/:id",
          "description": "Update an invoice",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "responses": {
            "200": { "description": "Invoice updated" },
            "404": { "description": "Invoice not found" }
          }
        },
        {
          "method": "DELETE",
          "path": "/api/invoices/:id",
          "description": "Delete an invoice",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "responses": {
            "204": { "description": "Invoice deleted" },
            "404": { "description": "Invoice not found" }
          }
        },
        {
          "method": "POST",
          "path": "/api/invoices/:id/mark-as-paid",
          "description": "Mark an invoice as paid and create a sale transaction",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "responses": {
            "200": { "description": "Invoice marked as paid, transaction created" },
            "404": { "description": "Invoice not found" }
          }
        },
        {
          "method": "POST",
          "path": "/api/invoices/:id/recalculate-taxes",
          "description": "Recalculate invoice taxes with optional new tax rate",
          "parameters": {
            "id": { "in": "path", "type": "string", "format": "uuid", "required": true },
            "tax_rate": { "in": "query", "type": "number", "description": "New tax rate (optional)" }
          },
          "responses": {
            "200": { "description": "Invoice with recalculated taxes" },
            "404": { "description": "Invoice not found" }
          }
        }
      ]
    },
    "tax": {
      "basePath": "/api/tax",
      "description": "GST/Tax calculations and filing features",
      "authRequired": true,
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/tax/gst",
          "description": "Calculate GST for an amount",
          "parameters": {
            "amount": { "in": "query", "type": "number", "required": true },
            "tax_included": { "in": "query", "type": "boolean", "default": false },
            "tax_rate": { "in": "query", "type": "number", "default": 18 }
          },
          "responses": {
            "200": {
              "schema": {
                "original_amount": { "type": "number" },
                "tax_rate": { "type": "number" },
                "tax_amount": { "type": "number" },
                "total_amount": { "type": "number" },
                "tax_included": { "type": "boolean" },
                "breakdown": {
                  "cgst": { "type": "number" },
                  "sgst": { "type": "number" }
                }
              }
            },
            "400": { "description": "amount is required" }
          },
          "example": "GET /api/tax/gst?amount=1000&tax_rate=18&tax_included=false"
        },
        {
          "method": "GET",
          "path": "/api/tax/calculate-for-invoice/:invoice_id",
          "description": "Calculate GST for a specific invoice",
          "parameters": {
            "invoice_id": { "in": "path", "type": "string", "format": "uuid", "required": true }
          },
          "responses": {
            "200": { "description": "GST breakdown for invoice" },
            "404": { "description": "Invoice not found" }
          }
        },
        {
          "method": "GET",
          "path": "/api/tax/filing",
          "description": "Get tax filing summary for a period",
          "parameters": {
            "start_date": { "in": "query", "type": "string", "format": "date", "required": true },
            "end_date": { "in": "query", "type": "string", "format": "date", "required": true },
            "tax_type": { "in": "query", "type": "string", "default": "gst" },
            "period": { "in": "query", "type": "string", "default": "quarterly" }
          },
          "responses": {
            "200": {
              "schema": {
                "summary": {
                  "period_start": { "type": "string" },
                  "period_end": { "type": "string" },
                  "tax_type": { "type": "string" },
                  "total_sales": { "type": "number" },
                  "total_tax_collected": { "type": "number" },
                  "total_tax_paid": { "type": "number" },
                  "net_tax_liability": { "type": "number" },
                  "transaction_count": { "type": "number" },
                  "status": { "type": "string" }
                },
                "transactions": { "type": "array" }
              }
            },
            "400": { "description": "start_date and end_date are required" }
          }
        },
        {
          "method": "GET",
          "path": "/api/tax/filing/auto-generate",
          "description": "Auto-generate tax filing for the last quarter",
          "responses": {
            "200": { "description": "Auto-generated tax filing" }
          }
        },
        {
          "method": "POST",
          "path": "/api/tax/submit",
          "description": "Submit tax filing",
          "responses": {
            "200": { "description": "Tax filing submitted" }
          }
        },
        {
          "method": "GET",
          "path": "/api/tax/report",
          "description": "Get tax report",
          "responses": {
            "200": { "description": "Tax report" }
          }
        }
      ]
    },
    "inventory": {
      "basePath": "/api/inventory",
      "description": "Inventory management with items, categories, images, and bulk upload",
      "authRequired": true,
      "categories": {
        "description": "Manage inventory categories",
        "endpoints": [
          {
            "method": "GET",
            "path": "/api/inventory/categories",
            "description": "List all categories for the current user",
            "responses": {
              "200": {
                "description": "Array of categories",
                "schema": {
                  "type": "array",
                  "items": {
                    "id": { "type": "string", "format": "uuid" },
                    "user_id": { "type": "string", "format": "uuid" },
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "created_at": { "type": "string", "format": "date-time" },
                    "updated_at": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          },
          {
            "method": "POST",
            "path": "/api/inventory/categories",
            "description": "Create a new category",
            "requestBody": {
              "contentType": "application/json",
              "required": ["name"],
              "schema": {
                "name": { "type": "string" },
                "description": { "type": "string" }
              },
              "example": { "name": "Electronics", "description": "Electronic devices and accessories" }
            },
            "responses": {
              "201": { "description": "Category created" },
              "400": { "description": "Category name is required" },
              "409": { "description": "Category already exists" }
            }
          },
          {
            "method": "PUT",
            "path": "/api/inventory/categories/:id",
            "description": "Update a category",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
            },
            "responses": {
              "200": { "description": "Category updated" },
              "404": { "description": "Category not found" },
              "409": { "description": "Category name already exists" }
            }
          },
          {
            "method": "DELETE",
            "path": "/api/inventory/categories/:id",
            "description": "Delete a category (items in category will have category_id set to null)",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
            },
            "responses": {
              "204": { "description": "Category deleted" },
              "404": { "description": "Category not found" }
            }
          }
        ]
      },
      "items": {
        "description": "Manage inventory items",
        "endpoints": [
          {
            "method": "GET",
            "path": "/api/inventory",
            "description": "List all inventory items with pagination, filtering, and search",
            "parameters": {
              "page": { "in": "query", "type": "number", "default": 1 },
              "limit": { "in": "query", "type": "number", "default": 50, "description": "Use 'all' for no pagination" },
              "search": { "in": "query", "type": "string", "description": "Search by name, SKU, or description" },
              "category_id": { "in": "query", "type": "string", "format": "uuid" },
              "is_active": { "in": "query", "type": "boolean" },
              "low_stock": { "in": "query", "type": "boolean", "description": "Filter items below threshold" },
              "sort": { "in": "query", "type": "string", "enum": ["name", "sku_id", "stock_quantity", "sell_price", "cost_price", "created_at", "updated_at"], "default": "created_at" },
              "order": { "in": "query", "type": "string", "enum": ["asc", "desc"], "default": "desc" }
            },
            "responses": {
              "200": {
                "schema": {
                  "items": { "type": "array" },
                  "pagination": {
                    "page": { "type": "number" },
                    "limit": { "type": "number" },
                    "total_items": { "type": "number" },
                    "total_pages": { "type": "number" }
                  }
                }
              }
            },
            "example": "GET /api/inventory?page=1&limit=20&search=iphone&sort=name&order=asc"
          },
          {
            "method": "POST",
            "path": "/api/inventory",
            "description": "Create a new inventory item",
            "requestBody": {
              "contentType": "application/json",
              "required": ["name", "sell_price", "cost_price"],
              "schema": {
                "name": { "type": "string", "description": "Item name" },
                "description": { "type": "string" },
                "stock_quantity": { "type": "integer", "default": 0 },
                "sell_price": { "type": "number", "description": "Selling price" },
                "cost_price": { "type": "number", "description": "Cost/purchase price" },
                "sku_id": { "type": "string", "description": "Custom SKU (required if auto_index is false)" },
                "auto_index": { "type": "boolean", "default": true, "description": "Auto-generate SKU if true" },
                "category_id": { "type": "string", "format": "uuid" },
                "low_stock_threshold": { "type": "integer", "default": 10 }
              },
              "examples": {
                "auto_sku": {
                  "name": "iPhone 15 Pro",
                  "stock_quantity": 50,
                  "sell_price": 999.99,
                  "cost_price": 750,
                  "auto_index": true,
                  "category_id": "uuid-here",
                  "low_stock_threshold": 5
                },
                "manual_sku": {
                  "name": "Samsung Galaxy S24",
                  "stock_quantity": 30,
                  "sell_price": 899.99,
                  "cost_price": 650,
                  "auto_index": false,
                  "sku_id": "SAMSUNG-S24-001"
                }
              }
            },
            "responses": {
              "201": {
                "description": "Item created",
                "schema": {
                  "id": { "type": "string", "format": "uuid" },
                  "name": { "type": "string" },
                  "sku_id": { "type": "string", "description": "Auto-generated or custom SKU" },
                  "stock_quantity": { "type": "integer" },
                  "sell_price": { "type": "number" },
                  "cost_price": { "type": "number" },
                  "auto_index": { "type": "boolean" },
                  "category_id": { "type": "string" },
                  "image_url": { "type": "string" },
                  "is_active": { "type": "boolean" },
                  "low_stock_threshold": { "type": "integer" },
                  "created_at": { "type": "string", "format": "date-time" },
                  "updated_at": { "type": "string", "format": "date-time" }
                }
              },
              "400": { "description": "Validation error" },
              "409": { "description": "SKU already exists" }
            }
          },
          {
            "method": "GET",
            "path": "/api/inventory/:id",
            "description": "Get a specific inventory item with category and images",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
            },
            "responses": {
              "200": { "description": "Item with category and images" },
              "404": { "description": "Item not found" }
            }
          },
          {
            "method": "PUT",
            "path": "/api/inventory/:id",
            "description": "Update an inventory item",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
            },
            "requestBody": {
              "schema": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "stock_quantity": { "type": "integer" },
                "sell_price": { "type": "number" },
                "cost_price": { "type": "number" },
                "sku_id": { "type": "string" },
                "category_id": { "type": "string", "format": "uuid", "nullable": true },
                "is_active": { "type": "boolean" },
                "low_stock_threshold": { "type": "integer" }
              }
            },
            "responses": {
              "200": { "description": "Item updated" },
              "404": { "description": "Item not found" },
              "409": { "description": "SKU already exists" }
            }
          },
          {
            "method": "DELETE",
            "path": "/api/inventory/:id",
            "description": "Delete an inventory item (also deletes all associated images)",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
            },
            "responses": {
              "204": { "description": "Item deleted" },
              "404": { "description": "Item not found" }
            }
          },
          {
            "method": "PATCH",
            "path": "/api/inventory/:id/stock",
            "description": "Adjust stock quantity (increment or decrement)",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
            },
            "requestBody": {
              "contentType": "application/json",
              "required": ["adjustment"],
              "schema": {
                "adjustment": { "type": "integer", "description": "Positive to add, negative to subtract" },
                "reason": { "type": "string", "description": "Optional reason for adjustment" }
              },
              "example": { "adjustment": -5, "reason": "Sold 5 units" }
            },
            "responses": {
              "200": {
                "schema": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "sku_id": { "type": "string" },
                  "previous_quantity": { "type": "integer" },
                  "adjustment_applied": { "type": "integer" },
                  "stock_quantity": { "type": "integer" },
                  "reason": { "type": "string" }
                }
              },
              "400": { "description": "Invalid adjustment or stock cannot go negative" },
              "404": { "description": "Item not found" }
            }
          },
          {
            "method": "GET",
            "path": "/api/inventory/low-stock",
            "description": "Get items that are at or below their low stock threshold",
            "responses": {
              "200": {
                "schema": {
                  "items": { "type": "array" },
                  "count": { "type": "number" }
                }
              }
            }
          },
          {
            "method": "GET",
            "path": "/api/inventory/export",
            "description": "Export inventory to spreadsheet file",
            "parameters": {
              "format": { "in": "query", "type": "string", "enum": ["xlsx", "csv"], "default": "xlsx" }
            },
            "responses": {
              "200": {
                "description": "File download",
                "contentType": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
              }
            }
          }
        ]
      },
      "bulkUpload": {
        "description": "Bulk upload inventory items from spreadsheet",
        "endpoints": [
          {
            "method": "POST",
            "path": "/api/inventory/bulk-upload",
            "description": "Upload a spreadsheet (Excel/CSV) to create multiple inventory items",
            "requestBody": {
              "contentType": "multipart/form-data",
              "schema": {
                "file": { "type": "file", "description": "Excel (.xlsx, .xls) or CSV file", "maxSize": "10MB" }
              },
              "spreadsheetFormat": {
                "requiredColumns": ["name", "stock_quantity", "sell_price", "cost_price"],
                "optionalColumns": ["sku_id", "category", "description", "low_stock_threshold"],
                "example": [
                  ["name", "stock_quantity", "sell_price", "cost_price", "sku_id", "category"],
                  ["iPhone 15", 50, 999.99, 750, "", "Electronics"],
                  ["Samsung TV", 20, 599.99, 400, "TV-SAM-001", "Electronics"]
                ]
              }
            },
            "responses": {
              "202": {
                "description": "Upload processed",
                "schema": {
                  "upload_id": { "type": "string", "format": "uuid" },
                  "status": { "type": "string", "enum": ["processing", "completed", "failed", "partial"] },
                  "total_rows": { "type": "number" },
                  "success_count": { "type": "number" },
                  "error_count": { "type": "number" },
                  "error_details": {
                    "type": "array",
                    "items": {
                      "row": { "type": "number" },
                      "field": { "type": "string" },
                      "error": { "type": "string" }
                    }
                  }
                }
              },
              "400": { "description": "Invalid file or parse error" }
            }
          },
          {
            "method": "GET",
            "path": "/api/inventory/bulk-upload/:id",
            "description": "Get the status and results of a bulk upload",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true }
            },
            "responses": {
              "200": { "description": "Upload log with status and errors" },
              "404": { "description": "Upload log not found" }
            }
          }
        ]
      },
      "images": {
        "description": "Manage multiple images per inventory item",
        "maxImagesPerItem": 10,
        "acceptedFormats": ["image/jpeg", "image/png", "image/webp", "image/gif"],
        "maxFileSize": "5MB",
        "endpoints": [
          {
            "method": "GET",
            "path": "/api/inventory/:id/images",
            "description": "Get all images for an inventory item",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true, "description": "Inventory item ID" }
            },
            "responses": {
              "200": {
                "schema": {
                  "item_id": { "type": "string", "format": "uuid" },
                  "images": {
                    "type": "array",
                    "items": {
                      "id": { "type": "string", "format": "uuid" },
                      "image_url": { "type": "string" },
                      "is_primary": { "type": "boolean" },
                      "sort_order": { "type": "integer" },
                      "created_at": { "type": "string", "format": "date-time" }
                    }
                  },
                  "count": { "type": "number" }
                }
              },
              "404": { "description": "Item not found" }
            }
          },
          {
            "method": "POST",
            "path": "/api/inventory/:id/images",
            "description": "Add a new image to an inventory item (max 10 per item)",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true, "description": "Inventory item ID" }
            },
            "requestBody": {
              "contentType": "multipart/form-data",
              "schema": {
                "image": { "type": "file", "description": "Image file (JPEG, PNG, WebP, GIF)", "maxSize": "5MB" }
              }
            },
            "responses": {
              "201": {
                "description": "Image added (first image is automatically set as primary)",
                "schema": {
                  "id": { "type": "string", "format": "uuid" },
                  "item_id": { "type": "string", "format": "uuid" },
                  "image_url": { "type": "string" },
                  "is_primary": { "type": "boolean" },
                  "sort_order": { "type": "integer" }
                }
              },
              "400": { "description": "No image provided or max images reached" },
              "404": { "description": "Item not found" }
            }
          },
          {
            "method": "DELETE",
            "path": "/api/inventory/:id/images/:imageId",
            "description": "Delete a specific image from an inventory item",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true, "description": "Inventory item ID" },
              "imageId": { "in": "path", "type": "string", "format": "uuid", "required": true, "description": "Image ID" }
            },
            "responses": {
              "200": { "description": "Image deleted (if primary was deleted, next image becomes primary)" },
              "404": { "description": "Item or image not found" }
            }
          },
          {
            "method": "PATCH",
            "path": "/api/inventory/:id/images/:imageId/primary",
            "description": "Set an image as the primary image for the item",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true, "description": "Inventory item ID" },
              "imageId": { "in": "path", "type": "string", "format": "uuid", "required": true, "description": "Image ID" }
            },
            "responses": {
              "200": {
                "schema": {
                  "message": { "type": "string" },
                  "image": { "type": "object" }
                }
              },
              "404": { "description": "Item or image not found" }
            }
          },
          {
            "method": "PUT",
            "path": "/api/inventory/:id/images/reorder",
            "description": "Reorder images for an inventory item",
            "parameters": {
              "id": { "in": "path", "type": "string", "format": "uuid", "required": true, "description": "Inventory item ID" }
            },
            "requestBody": {
              "contentType": "application/json",
              "required": ["image_order"],
              "schema": {
                "image_order": { "type": "array", "items": { "type": "string", "format": "uuid" }, "description": "Array of image IDs in desired order" }
              },
              "example": { "image_order": ["img3-uuid", "img1-uuid", "img2-uuid"] }
            },
            "responses": {
              "200": {
                "schema": {
                  "message": { "type": "string" },
                  "images": { "type": "array" }
                }
              },
              "400": { "description": "Invalid image_order" },
              "404": { "description": "Item not found" }
            }
          }
        ]
      }
    }
  },
  "models": {
    "User": {
      "tableName": "users",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "name": { "type": "STRING", "required": true },
        "email": { "type": "STRING", "required": true, "unique": true },
        "password": { "type": "STRING", "required": true, "description": "Hashed with bcrypt" },
        "createdAt": { "type": "DATE" },
        "updatedAt": { "type": "DATE" }
      }
    },
    "Account": {
      "tableName": "accounts",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "user_id": { "type": "UUID", "foreignKey": "User" },
        "name": { "type": "STRING", "default": "Default Account" },
        "balance": { "type": "FLOAT", "default": 0 },
        "default": { "type": "BOOLEAN", "default": false },
        "created_at": { "type": "DATE" },
        "updated_at": { "type": "DATE" }
      }
    },
    "Transaction": {
      "tableName": "transactions",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "amount": { "type": "FLOAT", "required": true },
        "description": { "type": "STRING", "required": true },
        "transaction_type": { "type": "ENUM", "values": ["sale", "expense", "transfer", "other"] },
        "category": { "type": "STRING" },
        "date": { "type": "DATE" },
        "user_id": { "type": "UUID", "foreignKey": "User" },
        "account_id": { "type": "UUID", "foreignKey": "Account" }
      }
    },
    "Invoice": {
      "tableName": "invoices",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "invoice_number": { "type": "STRING", "required": true },
        "customer_name": { "type": "STRING", "required": true },
        "customer_email": { "type": "STRING" },
        "customer_address": { "type": "STRING" },
        "issue_date": { "type": "DATE" },
        "due_date": { "type": "DATE" },
        "subtotal": { "type": "FLOAT" },
        "tax_rate": { "type": "FLOAT", "default": 18 },
        "tax_amount": { "type": "FLOAT" },
        "total_amount": { "type": "FLOAT" },
        "status": { "type": "ENUM", "values": ["draft", "sent", "paid", "cancelled", "overdue"] },
        "notes": { "type": "STRING" },
        "template": { "type": "ENUM", "values": ["default", "professional", "simple", "detailed"] },
        "user_id": { "type": "UUID", "foreignKey": "User" }
      }
    },
    "InvoiceItem": {
      "tableName": "invoice_items",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "description": { "type": "STRING", "required": true },
        "quantity": { "type": "FLOAT", "default": 1 },
        "unit_price": { "type": "FLOAT", "required": true },
        "amount": { "type": "FLOAT" },
        "tax_included": { "type": "BOOLEAN", "default": true },
        "invoice_id": { "type": "UUID", "foreignKey": "Invoice" }
      }
    },
    "InventoryItem": {
      "tableName": "inventory_items",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "user_id": { "type": "UUID", "foreignKey": "User" },
        "name": { "type": "STRING", "required": true },
        "description": { "type": "TEXT" },
        "stock_quantity": { "type": "INTEGER", "default": 0 },
        "sell_price": { "type": "FLOAT", "required": true },
        "cost_price": { "type": "FLOAT", "required": true },
        "sku_id": { "type": "STRING", "required": true, "unique": "per user" },
        "auto_index": { "type": "BOOLEAN", "default": true },
        "category_id": { "type": "UUID", "foreignKey": "InventoryCategory" },
        "image_url": { "type": "STRING", "description": "Primary image URL (backward compatible)" },
        "is_active": { "type": "BOOLEAN", "default": true },
        "low_stock_threshold": { "type": "INTEGER", "default": 10 },
        "created_at": { "type": "DATE" },
        "updated_at": { "type": "DATE" }
      }
    },
    "InventoryCategory": {
      "tableName": "inventory_categories",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "user_id": { "type": "UUID", "foreignKey": "User" },
        "name": { "type": "STRING", "required": true, "unique": "per user" },
        "description": { "type": "STRING" },
        "created_at": { "type": "DATE" },
        "updated_at": { "type": "DATE" }
      }
    },
    "InventoryImage": {
      "tableName": "inventory_images",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "item_id": { "type": "UUID", "foreignKey": "InventoryItem" },
        "image_url": { "type": "STRING", "required": true },
        "is_primary": { "type": "BOOLEAN", "default": false },
        "sort_order": { "type": "INTEGER", "default": 0 },
        "created_at": { "type": "DATE" }
      }
    },
    "BulkUploadLog": {
      "tableName": "bulk_upload_logs",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "user_id": { "type": "UUID", "foreignKey": "User" },
        "filename": { "type": "STRING", "required": true },
        "status": { "type": "ENUM", "values": ["processing", "completed", "failed", "partial"] },
        "total_rows": { "type": "INTEGER", "default": 0 },
        "success_count": { "type": "INTEGER", "default": 0 },
        "error_count": { "type": "INTEGER", "default": 0 },
        "error_details": { "type": "JSONB" },
        "created_at": { "type": "DATE" }
      }
    },
    "Token": {
      "tableName": "tokens",
      "description": "Stores revoked/blacklisted tokens for logout functionality",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "user_id": { "type": "UUID", "foreignKey": "User" },
        "token": { "type": "STRING", "required": true },
        "expires_at": { "type": "DATE", "required": true },
        "revoked": { "type": "BOOLEAN", "default": false }
      }
    }
  },
  "errorResponses": {
    "400": { "message": "Bad Request - Invalid input or missing required fields" },
    "401": { "message": "Unauthorized - Missing or invalid authentication token" },
    "403": { "message": "Forbidden - Access denied" },
    "404": { "message": "Not Found - Resource does not exist" },
    "409": { "message": "Conflict - Resource already exists (e.g., duplicate email, SKU)" },
    "500": { "message": "Internal Server Error" }
  }
}
